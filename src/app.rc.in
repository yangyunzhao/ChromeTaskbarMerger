#include <winver.h>

1 VERSIONINFO
 FILEVERSION @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
 PRODUCTVERSION @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
 FILEFLAGSMASK VS_FFI_FILEFLAGSMASK
 FILEFLAGS VS_FF_PRERELEASE
 FILEOS VOS_NT_WINDOWS32
 FILETYPE VFT_APP
 FILESUBTYPE VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904B0"
        BEGIN
            VALUE "CompanyName", "ChromeTaskbarMerger contributors\0"
            VALUE "FileDescription", "Chrome taskbar single-entry manager\0"
            VALUE "FileVersion", "@PROJECT_VERSION@-rc1\0"
            VALUE "InternalName", "ChromeTaskbarMerger\0"
            VALUE "LegalCopyright", "Copyright (c) 2026 ChromeTaskbarMerger contributors\0"
            VALUE "OriginalFilename", "ChromeTaskbarMerger.exe\0"
            VALUE "ProductName", "ChromeTaskbarMerger\0"
            VALUE "ProductVersion", "@PROJECT_VERSION@-rc1\0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 1200
    END
END
